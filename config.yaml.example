server:
  host: "0.0.0.0"
  port: 18120
  admin_password: "your-admin-password-here"
  agent_enroll_token: "your-agent-enroll-token-here"

storage:
  objects_dir: "./data/objects"
  db_path: "./data/meta.sqlite"
  max_file_size_gb: 10

security:
  session_timeout_minutes: 60
  download_token_timeout_minutes: 10

websocket:
  ping_interval_seconds: 10
  pong_timeout_seconds: 30
  heartbeat_interval_seconds: 15

logging:
  level: "info"
  output: "stdout"
  # Enable time-based log rotation (optional)
  # log_dir: "C:/logs/remote-file-logs"
  # use_rotate: true

mcp:
  enabled: true
  # Generate a secure random token: openssl rand -base64 32
  auth_token: "your-mcp-auth-token-here"
  session_timeout_minutes: 30
  endpoint: "/mcp"
